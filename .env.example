# Copie este arquivo para .env e preencha com seus valores
# Na Vercel, configure como variáveis de ambiente no painel do projeto

# ── Supabase (obrigatório) ────────────────────────────────────────────────────
VITE_SUPABASE_URL=https://SEU_PROJETO.supabase.co
VITE_SUPABASE_ANON_KEY=sua_anon_key_aqui

# ── IA em cascata para leitura da maquininha (todos opcionais) ────────────────
# O sistema tenta na ordem: Gemini → Mistral → OpenRouter → Tesseract (local)
# Configure ao menos um para ativar a leitura por IA.

# Google Gemini 2.0 Flash — grátis: 15 req/min, 1500/dia
# Chave em: https://aistudio.google.com/apikey
VITE_GEMINI_API_KEY=

# Mistral Pixtral-12b — grátis no tier gratuito
# Chave em: https://console.mistral.ai
VITE_MISTRAL_API_KEY=

# OpenRouter — agrega modelos gratuitos (Gemini, LLaMA, Qwen Vision)
# Chave em: https://openrouter.ai (conta gratuita)
VITE_OPENROUTER_API_KEY=
